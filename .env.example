# Copie este arquivo para .env.local e preencha com suas chaves reais

# Resend (transacional de e-mail)
RESEND_API_KEY=

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# JWT Admin (gere com: openssl rand -hex 32)
JWT_SECRET=

# Email do admin que receberá os leads
ADMIN_EMAIL=

# Flag para indicar ambiente Cloudflare Pages (1 em produção)
CF_PAGES=0
